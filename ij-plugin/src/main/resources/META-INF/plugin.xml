<idea-plugin>
    <id>com.jonnyzzz.intellij.mcp-steroid</id>
    <name>MCP Steroid</name>
    <vendor>jonnyzzz.com</vendor>

    <description><![CDATA[
    <p><strong>MCP Steroid</strong> brings the full power of the IntelliJ Platform to AI agents through the Model Context Protocol (MCP).</p>

    <p><b>IntelliJ platform works for AI agents as great as for human developers.</b></p>

    <p>MCP Steroid is an independent research project by Eugene Petrenko (jonnyzzz). Not affiliated with, endorsed by, or supported by JetBrains s.r.o.</p>

    <h3>What You Get</h3>
    <ul>
        <li><b>9 MCP Tools:</b> Control IntelliJ IDEA programmatically - execute code, take screenshots, discover actions, debug, and more</li>
        <li><b>58 MCP Resources:</b> Comprehensive guides covering LSP, IDE operations, debugger, tests, VCS, and more</li>
        <li><b>Vision Capabilities:</b> AI agents can see your IDE with screenshots and OCR (unique to MCP Steroid)</li>
        <li><b>Deep Integration:</b> Access PSI, inspections, refactorings, and full IntelliJ Platform API</li>
        <li><b>Human Oversight:</b> Review and approve code execution with configurable safety controls</li>
    </ul>

    <h3>Why MCP Steroid?</h3>
    <p>Unlike LSP-only solutions, MCP Steroid gives AI agents the same powerful IDE capabilities that developers use - semantic understanding, advanced refactorings, debugging, test running, and visual awareness.</p>

    <p><b>Compatible with all IntelliJ Platform-based IDEs:</b> IntelliJ IDEA, PyCharm, WebStorm, GoLand, CLion, Rider, and more.</p>

    <p><b>Requirements:</b> IntelliJ IDEA 2025.3 or newer (build 253 or later)</p>

    <br />
    <h3>Demo: CodeDozer & IntelliJ Debugger</h3>
    <iframe width="560" height="315" src="https://www.youtube.com/embed/8MjogrpfXLU" frameborder="0" allowfullscreen></iframe>
    <br /><br />

    <p>Visit <a href="https://mcp-steroid.jonnyzzz.com">https://mcp-steroid.jonnyzzz.com</a> for documentation and examples.</p>

    <p><small>IntelliJ IDEA, IntelliJ Platform, PyCharm, WebStorm, and JetBrains are trademarks of JetBrains s.r.o.</small></p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensionPoints>
        <!-- Extension point for registering MCP tools and resources -->
        <extensionPoint
            name="mcpRegistrar"
            interface="com.jonnyzzz.intellij.mcp.server.McpRegistrar"
            dynamic="true"/>

        <!-- Extension point for screenshot metadata providers -->
        <extensionPoint
            name="screenshotMetadataProvider"
            interface="com.jonnyzzz.intellij.mcp.vision.ScreenshotMetadataProvider"
            dynamic="true"/>
    </extensionPoints>

    <!-- MCP tool and resource registrars -->
    <extensions defaultExtensionNs="com.jonnyzzz.intellij.mcp-steroid">
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ListProjectsToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ListWindowsToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ExecuteCodeToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ExecuteFeedbackToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.CapabilitiesToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ActionDiscoveryToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.VisionScreenshotToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.VisionInputToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.OpenProjectToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.SkillResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.DebuggerSkillResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.LspExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.IdeExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.DebuggerExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.TestSkillResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.TestExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.OpenProjectResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.VcsExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ResourceGraphHandler"/>

        <!-- Screenshot metadata providers -->
        <screenshotMetadataProvider implementation="com.jonnyzzz.intellij.mcp.vision.ScreenshotImageProvider"/>
        <screenshotMetadataProvider implementation="com.jonnyzzz.intellij.mcp.vision.SwingComponentTreeProvider"/>
        <screenshotMetadataProvider implementation="com.jonnyzzz.intellij.mcp.vision.OcrMetadataProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Update checker notification group -->
        <notificationGroup id="jonnyzzz.mcp.steroid.updates"
                           displayType="BALLOON"/>

        <!-- Demo Mode overlay service (project-level) -->
        <projectService
            serviceImplementation="com.jonnyzzz.intellij.mcp.demo.DemoModeService"
            preload="true"/>

        <!-- Review panel notification -->
        <editorNotificationProvider
            implementation="com.jonnyzzz.intellij.mcp.review.McpReviewNotificationProvider"/>

        <!-- Registry keys for configuration -->
        <registryKey key="mcp.steroid.review.mode" defaultValue="ALWAYS"
            description="Code review mode: ALWAYS (default), TRUSTED, NEVER"/>

        <registryKey key="mcp.steroid.review.timeout" defaultValue="600"
            description="Review timeout in seconds"/>

        <registryKey key="mcp.steroid.execution.timeout" defaultValue="600"
            description="Script execution timeout in seconds"/>

        <registryKey key="mcp.steroid.server.port" defaultValue="6315"
            description="MCP server port (0 for auto-assign)"/>

        <registryKey key="mcp.steroid.server.host" defaultValue="127.0.0.1"
            description="MCP server bind address (use 0.0.0.0 for Docker access)"/>

        <!-- Demo Mode registry keys -->
        <registryKey key="mcp.steroid.demo.enabled" defaultValue="false"
            description="Enable Demo Mode overlay for MCP execution"/>
        <registryKey key="mcp.steroid.demo.minDisplayTime" defaultValue="3000"
            description="Minimum display time in milliseconds"/>
        <registryKey key="mcp.steroid.demo.maxLines" defaultValue="15"
            description="Maximum log lines to show in overlay"/>
        <registryKey key="mcp.steroid.demo.opacity" defaultValue="85"
            description="Background opacity (0-100)"/>
        <registryKey key="mcp.steroid.demo.focusFrame" defaultValue="true"
            description="Bring project frame to front when showing overlay"/>

        <!-- Update checker registry keys -->
        <registryKey key="mcp.steroid.updates.enabled" defaultValue="true"
            description="Enable automatic update checks"/>

        <!-- Storage folder configuration -->
        <registryKey key="mcp.steroid.storage.path" defaultValue=""
            description="Custom path for MCP execution storage. Empty (default) uses ~/.mcp-steroid"/>
        <registryKey key="mcp.steroid.idea.description.enabled" defaultValue="true"
            description="Generate .idea/mcp-steroid.md description file in projects"/>

        <!-- Start MCP server when IDE is ready -->
        <postStartupActivity
                implementation="com.jonnyzzz.intellij.mcp.server.SteroidsMcpServerStartupActivity"/>
    </extensions>

</idea-plugin>
