<idea-plugin>
    <id>com.jonnyzzz.intellij.mcp-steroid</id>
    <name>MCP Steroid</name>
    <vendor>jonnyzzz.com</vendor>

    <description><![CDATA[
    MCP Server plugin for IntelliJ IDEA that allows LLM agents to execute Kotlin code
    in the IDE's runtime environment with full access to IDE APIs.
    Runs its own MCP server using Kotlin MCP SDK with SSE transport.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends optional="true" config-file="kotlin-scripting.xml">org.jetbrains.kotlin</depends>

    <extensionPoints>
        <!-- Extension point for registering MCP tools and resources -->
        <extensionPoint
            name="mcpRegistrar"
            interface="com.jonnyzzz.intellij.mcp.server.McpRegistrar"
            dynamic="true"/>

        <!-- Extension point for screenshot metadata providers -->
        <extensionPoint
            name="screenshotMetadataProvider"
            interface="com.jonnyzzz.intellij.mcp.vision.ScreenshotMetadataProvider"
            dynamic="true"/>
    </extensionPoints>

    <!-- MCP tool and resource registrars -->
    <extensions defaultExtensionNs="com.jonnyzzz.intellij.mcp-steroid">
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ListProjectsToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ListWindowsToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ExecuteCodeToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ExecuteFeedbackToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.CapabilitiesToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.ActionDiscoveryToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.VisionScreenshotToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.VisionInputToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.OpenProjectToolHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.SkillResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.LspExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.IdeExamplesResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.OpenProjectResourceHandler"/>
        <mcpRegistrar implementation="com.jonnyzzz.intellij.mcp.server.VcsExamplesResourceHandler"/>

        <!-- Screenshot metadata providers -->
        <screenshotMetadataProvider implementation="com.jonnyzzz.intellij.mcp.vision.SwingComponentTreeProvider"/>
        <screenshotMetadataProvider implementation="com.jonnyzzz.intellij.mcp.vision.OcrMetadataProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Review panel notification -->
        <editorNotificationProvider
            implementation="com.jonnyzzz.intellij.mcp.review.McpReviewNotificationProvider"/>

        <!-- Registry keys for configuration -->
        <registryKey key="mcp.steroids.review.mode" defaultValue="ALWAYS"
            description="Code review mode: ALWAYS (default), TRUSTED, NEVER"/>

        <registryKey key="mcp.steroids.review.timeout" defaultValue="600"
            description="Review timeout in seconds"/>

        <registryKey key="mcp.steroids.execution.timeout" defaultValue="600"
            description="Script execution timeout in seconds"/>

        <registryKey key="mcp.steroids.server.port" defaultValue="6315"
            description="MCP server port (0 for auto-assign)"/>

        <registryKey key="mcp.steroids.server.host" defaultValue="127.0.0.1"
            description="MCP server bind address (use 0.0.0.0 for Docker access)"/>

        <!-- Start MCP server when IDE is ready -->
        <postStartupActivity
                implementation="com.jonnyzzz.intellij.mcp.server.SteroidsMcpServerStartupActivity"/>
    </extensions>

</idea-plugin>
